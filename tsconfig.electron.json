{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "CommonJS",
		"moduleResolution": "node",
		"skipLibCheck": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"types": ["node"]
	},
	"include": ["electron"]
}

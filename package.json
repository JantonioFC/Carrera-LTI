{
	"name": "carrera-lti",
	"private": true,
	"version": "1.0.0",
	"license": "CC-BY-NC-4.0",
	"type": "module",
	"main": "dist-electron/main.js",
	"scripts": {
		"dev": "vite",
		"dev:electron": "cross-env VITE_ELECTRON=true vite",
		"build": "tsc -b && vite build",
		"build:electron": "cross-env VITE_ELECTRON=true tsc -b && cross-env VITE_ELECTRON=true vite build && electron-builder",
		"preview": "vite preview",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"setup": "node scripts/setup.mjs",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@blocknote/core": "^0.47.1",
		"@blocknote/mantine": "^0.47.1",
		"@blocknote/react": "^0.47.1",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@google/genai": "^1.45.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@uiw/react-md-editor": "^4.0.11",
		"@xyflow/react": "^12.10.1",
		"d3-force": "^3.0.0",
		"dexie": "^4.3.0",
		"dexie-react-hooks": "^4.2.0",
		"electron-store": "^11.0.2",
		"firebase": "^12.10.0",
		"framer-motion": "^12.36.0",
		"idb-keyval": "^6.2.2",
		"immer": "^11.1.4",
		"lucide-react": "^0.577.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-force-graph-2d": "^1.29.1",
		"react-router-dom": "^7.13.1",
		"recharts": "^3.8.0",
		"rehype-sanitize": "^6.0.0",
		"uuid": "^13.0.0",
		"y-indexeddb": "^9.0.12",
		"yjs": "^13.6.30",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@clack/prompts": "^1.1.0",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.5.0",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"@vitest/coverage-v8": "^4.1.1",
		"cross-env": "^10.1.0",
		"electron": "^41.0.3",
		"electron-builder": "^26.8.1",
		"jsdom": "^29.0.0",
		"memfs": "^4.17.0",
		"picocolors": "^1.1.1",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.9.3",
		"vite": "^8.0.0",
		"vite-plugin-electron": "^0.29.1",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.0"
	},
	"build": {
		"appId": "com.carreralti.app",
		"productName": "Carrera LTI",
		"copyright": "Copyright © 2026 Carrera LTI",
		"directories": {
			"output": "dist-electron/release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/main.js",
			"dist-electron/preload.mjs",
			"dist-electron/electron-store-*.js",
			"scripts/**/*.py",
			"package.json"
		],
		"win": {
			"target": "nsis",
			"icon": "public/icon.ico"
		},
		"mac": {
			"target": "dmg",
			"icon": "public/icon.icns",
			"category": "public.app-category.education"
		},
		"linux": {
			"target": "AppImage",
			"icon": "public/icon.png",
			"category": "Education"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		}
	},
	"overrides": {
		"serialize-javascript": "7.0.3",
		"@tailwindcss/vite": {
			"vite": "^8.0.0"
		},
		"vite-plugin-pwa": {
			"vite": "^8.0.0"
		},
		"vite-plugin-electron": {
			"vite": "^8.0.0"
		}
	}
}

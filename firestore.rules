rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la app Carrera LTI
    
    // Función auxiliar para validar que el usuario no envíe más de 1MB por documento (Rate limiting básico)
    function isValidSize() {
      return request.resource.size < 1048576; // 1 MB
    }

    match /users/{userId}/{document=**} {
      // Solo el propietario puede leer y escribir.
      // Además validamos el tamaño del documento para prevenir abuso.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && isValidSize();
    }
    
    // Denegar cualquier otro acceso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
